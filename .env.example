# Copy to .env and fill in. Do not commit real secrets.

# PRODUCTION_MODE=true
# Real cart recovery WhatsApp (POST JSON: phone, message; Bearer WHATSAPP_API_KEY)
# WHATSAPP_API_URL=https://your-proxy-or-provider.example.com/whatsapp/send
# WHATSAPP_API_KEY=

# Optional: send recovery only to this number while testing (e.g. your WhatsApp Business test line).
# If unset, the legacy mock destination 0500000000 is used with mock sends.
# WHATSAPP_RECOVERY_TO_PHONE=
