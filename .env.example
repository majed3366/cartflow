# Copy to .env and fill in. Do not commit real secrets.

# PRODUCTION_MODE=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886
# Delivery status callbacks (optional; else CARTFLOW_PUBLIC_BASE_URL + /webhook/whatsapp/status)
# TWILIO_STATUS_CALLBACK_URL=https://your-host/webhook/whatsapp/status
# CARTFLOW_PUBLIC_BASE_URL=https://your-host
# OAUTH_REDIRECT_URI=https://your-host/auth/callback
# Must match Zid Partner Dashboard allowed redirection URLs exactly (https, no trailing slash).
# ZID_CLIENT_ID=
# ZID_CLIENT_SECRET=
# OAuth scopes (space-separated). Must match Application Scopes in Partner Dashboard.
# Default when unset: abandoned_carts.read orders.read
# ZID_OAUTH_SCOPE=abandoned_carts.read orders.read
# Development-store activation from Zid Partner marketplace (not public launch):
# ZID_DEV_OAUTH_ENABLED=1

# Merchant password reset (Resend)
# RESEND_API_KEY=re_...
# RESEND_FROM_EMAIL=CartFlow <auth@your-verified-domain.com>

# Demo store only: when cart/session has no verified phone, recovery WhatsApp uses this number.
# CARTFLOW_DEMO_TEST_PHONE=966579706669

# Cart recovery send queue: worker polls at most this often when idle; jobs are processed on arrival.
# WHATSAPP_QUEUE_INTERVAL_SECONDS=2
# Backoff between retry attempts (max 3 sends per enqueued job).
# WHATSAPP_QUEUE_RETRY_BACKOFF_SECONDS=1
