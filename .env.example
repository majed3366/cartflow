# Copy to .env and fill in. Do not commit real secrets.

# PRODUCTION_MODE=true
# TWILIO_ACCOUNT_SID=
# TWILIO_AUTH_TOKEN=
# TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# Optional: send recovery only to this number while testing (e.g. your WhatsApp Business test line).
# If unset, the legacy mock destination 966501234567 is used with mock sends.
# WHATSAPP_RECOVERY_TO_PHONE=

# Cart recovery send queue: worker polls at most this often when idle; jobs are processed on arrival.
# WHATSAPP_QUEUE_INTERVAL_SECONDS=2
# Backoff between retry attempts (max 3 sends per enqueued job).
# WHATSAPP_QUEUE_RETRY_BACKOFF_SECONDS=1
