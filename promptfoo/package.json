{
  "name": "cartflow-promptfoo-matrix",
  "private": true,
  "description": "Promptfoo eval for recovery-copy discipline (stub provider; no API keys required).",
  "scripts": {
    "gen": "node -e \"require('child_process').execSync('python ../scripts/generate_promptfoo_scenarios.py',{stdio:'inherit',cwd:__dirname})\"",
